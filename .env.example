# ==========================================
# Xanh SM Production RAG - Configurations Template
# Copy file này thành .env và điền các Key của bạn
# ==========================================

# 🔑 API Keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
GROQ_API_KEY=YOUR_GROQ_API_KEY

# 🤖 Cấu hình LLM & Embedding ("openai" hoặc "local")
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
RAG_ANSWER_MODEL=gpt-4o-mini
NLU_MODEL=llama-3.3-70b-versatile
FOOD_ANSWER_MODEL=gpt-4o-mini
AI_JUDGE_MODEL=gpt-4o-mini
VLM_MODEL=gpt-4o-mini

# 🚀 Cấu hình Reranker ("cohere")
RERANKER_PROVIDER=cohere
RERANKER_MODEL=rerank-multilingual-v3.0
COHERE_API_KEY=YOUR_COHERE_API_KEY

# 📂 Cấu hình đường dẫn dữ liệu
DATA_DIR=./data

# 🎯 Tinh chỉnh Retrieval & RAG
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=50
RETRIEVAL_CANDIDATE_LIMIT=25
RERANK_TOP_N=8
CONTEXT_EXPANSION_THRESHOLD=0.5
MAX_CHUNKS_PER_SECTION=10
OPENAI_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=1800
FOOD_SEARCH_RADIUS_KM=8
NOMINATIM_USER_AGENT=xanhsm-modular-ai/1.0
OSRM_BASE_URL=https://router.project-osrm.org

# ==========================================
# Database & VectorDB Configurations
# ==========================================

# 🗄️ Database (Lưu trữ User, Lịch sử Chat, Logs)
# Local mặc định dùng PostgreSQL từ docker-compose.yml
DATABASE_URL=postgresql://postgres:password@localhost:5432/greensm_db

# 🗄️ Vector Database (Qdrant Cloud hoặc Local)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=YOUR_QDRANT_API_KEY

# ==========================================
# 🔐 Authentication
# ==========================================
# Khóa bí mật JWT
SECRET_KEY=super-secret-key-for-jwt-change-in-production

# 🔑 Google Auth Client ID (Sử dụng cho Login Google)
GOOGLE_CLIENT_ID=your-google-client-id-here

# Food geocoding hiện dùng free providers: OpenStreetMap Nominatim + Photon fallback.
# Không cần Google Maps API key / Visa cho backend geocode.
# Nếu sau này frontend tích hợp bản đồ thật, có thể dùng Leaflet + OpenStreetMap tiles để tránh API key.

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
