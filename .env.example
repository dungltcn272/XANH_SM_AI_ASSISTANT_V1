# ==========================================
# Xanh SM Production RAG - Configurations Template
# Copy file này thành .env và điền các Key của bạn
# ==========================================

# 🔑 Dán OpenAI API Key của bạn vào đây:
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# 🤖 Cấu hình LLM & Embedding ("openai" hoặc "local")
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# 🚀 Cấu hình Reranker ("cohere")
RERANKER_PROVIDER=cohere
RERANKER_MODEL=rerank-v3.0
COHERE_API_KEY=YOUR_COHERE_API_KEY

# 📂 Cấu hình đường dẫn dữ liệu
DATA_DIR=./data

# ==========================================
# Database & VectorDB Configurations
# ==========================================

# 🗄️ Database (Lưu trữ User, Lịch sử Chat, Logs)
# Sử dụng SQLite cho Local testing, đổi thành PostgreSQL khi deploy production
DATABASE_URL=sqlite:///./greensm.db

# 🗄️ Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333

# ==========================================
# 🔐 Authentication
# ==========================================
# Khóa bí mật JWT
SECRET_KEY=super-secret-key-for-jwt-change-in-production

# 🔑 Google Auth Client ID (Sử dụng cho Login Google)
GOOGLE_CLIENT_ID=your-google-client-id-here
