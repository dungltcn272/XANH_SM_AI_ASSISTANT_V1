# ==============================================================================
# 🚗 Xanh SM Production RAG - Environment Configurations Template (.env.example)
# ==============================================================================
# Sao chép file này thành file ".env" ở cùng thư mục và điền các khóa cấu hình của bạn.

# 🔑 OpenAI API Key (Yêu cầu bắt buộc để chạy luồng sinh câu trả lời nâng cao)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# 🧠 Cấu hình Embedding Provider ("openai", "local", hoặc "mock")
# - "openai": Sử dụng OpenAI API (Khuyên dùng cho production).
# - "local": Sử dụng mô hình Sentence-Transformers chạy cục bộ (Yêu cầu máy cấu hình tốt).
# - "mock": Chạy ngoại tuyến, tự tạo danh sách vector trống (Phù hợp để test offline resilient).
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# 🗄️ Cấu hình Nhà cung cấp Vector Database ("chromadb" hoặc "fallback")
# - "chromadb": Sử dụng CSDL ChromaDB persistent thật (Phù hợp trên Railway / Linux).
# - "fallback": Chuyển hướng sang cơ sở dữ liệu In-Memory an toàn (Tránh crash lỗi SQLite C++ DLL trên Windows).
CHROMA_PROVIDER=fallback

# 🗄️ Cấu hình thư mục lưu trữ Vector Database
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=xanh_sm_rag

# 🚀 Cấu hình Reranker ("local", "flashrank", "cohere", hoặc "heuristic")
# - "local": Sử dụng Cross-Encoder (như MiniLM) chạy cục bộ (Chính xác cao, cần RAM).
# - "flashrank": Sử dụng bộ xếp hạng siêu tốc ONNX (FlashRank).
# - "cohere": Sử dụng Cohere Rerank v3 API (Yêu cầu COHERE_API_KEY).
# - "heuristic": Thuật toán sắp xếp từ khóa Heuristic (Mặc định nếu để none - Miễn phí, 0ms).
RERANKER_PROVIDER=local
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# 🔑 Cohere API Key (Chỉ cần khi RERANKER_PROVIDER=cohere)
COHERE_API_KEY=


# 🤖 Cấu hình Mô hình Ngôn ngữ lớn (LLM Synthesizer)
LLM_MODEL=gpt-4o-mini

# 📁 Đường dẫn lưu trữ tài liệu chính sách Markdown thô
# - Local mặc định: "./data"
# - Railway Volume khuyên dùng: "/app/persistent_storage/data"
DATA_DIR=./data

# 🕸️ Cấu hình Web Crawler
MAX_CRAWL_DEPTH=3
MAX_CRAWL_PAGES=50
CRAWL_START_URL=https://www.xanhsm.com/
